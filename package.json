{
  "name": "langgraph-js-starter",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "concurrently \"bun run dev:ui\" \"bun run dev:agent\" --names ui,agent --prefix-colors blue,green --kill-others",
    "dev:debug": "LOG_LEVEL=debug bun run dev",
    "dev:ui": "next dev --turbopack",
    "dev:agent": "cd agent && bun run dev",
    "build": "next build",
    "build:webpack": "next build --webpack",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "bun run typecheck",
    "install:agent": "cd agent && bun install",
    "postinstall": "bun run install:agent"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.57",
    "@copilotkit/react-core": "1.62.3",
    "@copilotkit/runtime": "1.62.3",
    "hono": "^4.12.10",
    "next": "^16.2.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
