{
  "name": "agent",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "langgraphjs dev --port 8123 --no-browser",
    "dev:docker": "langgraphjs dev --host 0.0.0.0 --port 8123 --no-browser",
    "start": "langgraphjs dev --host 0.0.0.0 --port ${PORT:-8000} --no-browser --no-reload --n-jobs-per-worker 1 --config ./langgraph.koyeb.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@copilotkit/sdk-js": "1.62.3",
    "@langchain/core": "1.1.49",
    "@langchain/langgraph-cli": "1.2.4",
    "@langchain/openai": "1.4.4",
    "langchain": "1.3.4"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
}