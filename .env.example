# For `next dev` and `cf:preview`, point this at a running LangGraph API.
# In Cloudflare Workers, configure the public HTTPS agent URL as a runtime
# environment variable instead; do not deploy a localhost value.
AGENT_URL=http://localhost:8123
OPENAI_API_KEY=

